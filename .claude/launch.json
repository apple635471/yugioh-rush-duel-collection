{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "rd-checklist-backend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-lc", "uv run uvicorn rd_checklist.main:app --reload --port 8000"],
      "port": 8000,
      "cwd": "apps/rd-checklist/backend"
    },
    {
      "name": "rd-checklist-frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-lc", "npm run dev"],
      "port": 5173,
      "cwd": "apps/rd-checklist/frontend"
    }
  ]
}
