{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "rd-checklist-backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "rd_checklist.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "apps/rd-checklist/backend"
    },
    {
      "name": "rd-checklist-frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "apps/rd-checklist/frontend"
    }
  ]
}
